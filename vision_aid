void angle(double result[2]) {

  mpu.update();
  

  unsigned long now = millis();
  dt = (now - lastMPUTime) * 0.001;   // convert ms → seconds
  lastMPUTime = now;

  float ax = mpu.getAccX();
  float ay = mpu.getAccY();
  float az = mpu.getAccZ();

  float gx = mpu.getGyroX();
  float gy = mpu.getGyroY();

  // Accelerometer angles
  float accRoll  = atan2(ay, az) * 180.0 / PI;
  float accPitch = atan2(-ax, sqrt(ay * ay + az * az)) * 180.0 / PI;

  // Gyro integration
  roll  += gx * dt;
  pitch += gy * dt;

  const float alpha = 0.97;

  // Complementary filter
  roll  = alpha * roll  + (1 - alpha) * accRoll;
  pitch = alpha * pitch + (1 - alpha) * accPitch;

  result[0] = pitch;
  result[1] = roll;
}

    void noPattern(){
      ledcWrite(leftmotor, 0);
      ledcWrite(rightmotor, 0);
    }
     
    void patternSide(bool leftActive, bool rightActive, double  left , double right){
            
             if(leftActive){// left is active 
                    
                    int pwm = map((int)left,0,side_threshold,255,100);
                    ledcWrite(leftmotor, pwm);
                   
             }
             else {
                     ledcWrite(leftmotor, 0);
             }
    
             
             
             if(rightActive){// left is active 
                    
                    int pwm = map((int)right,0,side_threshold,255,100);
                    ledcWrite(rightmotor, pwm);
                   
             }
             else {
                     ledcWrite(rightmotor, 0);
             }

           
    } 

    void patternFront(double front){
     
        int strength=map((int)front,0,front_threshold,255,100);
  
        // has enough time passed since last pulse  .... just toggle on and off 
        if(millis()-lastPulse>pulseInterval){
          lastPulse=millis();
          pulseState=!pulseState;
        }

        if(pulseState){
          ledcWrite(leftmotor, strength);
          ledcWrite(rightmotor, strength);
        }
         else{
           noPattern();
    }
    }

void patternDrop()
{
  static unsigned long last = 0;
  static int step = 0;

  if(millis() - last > 120)
  {
    last = millis();
    step++;

    if(step > 4) step = 0;
  }

  int intensity;

  switch(step)
  {
    case 0: intensity = 255; break;  // very strong
    case 1: intensity = 180; break;  // medium
    case 2: intensity = 100; break;  // weak
    case 3: intensity = 180; break;  // medium
    case 4: intensity = 255; break;  // strong again
  }

  ledcWrite(leftmotor, intensity);
  ledcWrite(rightmotor, intensity);
}

     void patternRaise() // bb ... bb .... bb ....bb  
    {  
       
  static unsigned long last = 0;
  static int step = 0;

  if(millis() - last > 120)
  {
    last = millis();
    step++;

    if(step > 5) step = 0;
  }

  if(step == 0 || step == 2)
  {
    ledcWrite(leftmotor, 240);
    ledcWrite(rightmotor, 240);
  }
  else
  {
    noPattern();
  }
}



