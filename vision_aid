   void calibrateHeight(double height)
{
  if(calibrated) return;

  if(height<=0) return;

  calibrationSum += height;
  calibrationCount++;

  if(calibrationCount >= CALIBRATION_LOOPS)
  {
    Height_global = calibrationSum / calibrationCount;
    calibrated = true;

    Serial.print("Ground Height Calibrated: ");
    Serial.println(Height_global);
  }
}




bool checkElevation(double height)
{
  if(!calibrated) return false;

  double delta = Height_global - height;

  if(delta > ELEVATION_THRESHOLD)
  {
    return true;
  }

  return false;
}




