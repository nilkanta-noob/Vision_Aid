void setup() {  
  Serial.begin(115200);
  Wire.begin(SDA_PIN, SCL_PIN);

  Serial.println("MPU6050 Test Starting...");

  mpu.begin();
  mpu.calcGyroOffsets(true);  
  // initialize pitch and roll from accelerometer
mpu.update();
mpu.update();
mpu.update();
lastMPUTime=millis();

lastMPUTime = millis();

  Serial.println("MPU6050 Ready");
  
  
  // oled display 
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
  Serial.println("OLED not found");
  while(true);
}

display.clearDisplay();
display.setTextSize(1);
display.setTextColor(SSD1306_WHITE);
display.display();

  


  delay(200);

  // Start I2C


  // Set XSHUT pins as output
  pinMode(XSHUT_LEFT, OUTPUT);
  pinMode(XSHUT_FRONT, OUTPUT);
  pinMode(XSHUT_RIGHT, OUTPUT);
  pinMode(XSHUT_DOWN, OUTPUT);

  // Turn ALL sensors OFF
  digitalWrite(XSHUT_LEFT, LOW);
  digitalWrite(XSHUT_FRONT, LOW);
  digitalWrite(XSHUT_RIGHT, LOW);
  digitalWrite(XSHUT_DOWN, LOW);
  delay(50);

  // left
  digitalWrite(XSHUT_LEFT, HIGH);     // turn ON
  delay(50);
  leftSensor.begin(0x29, &Wire);      // default address
  leftSensor.setAddress(ADDR_LEFT);   // change address

  // front
  digitalWrite(XSHUT_FRONT, HIGH);
  delay(50);
  frontSensor.begin(0x29, &Wire);
  frontSensor.setAddress(ADDR_FRONT);

  // RIGHT 
  digitalWrite(XSHUT_RIGHT, HIGH);
  delay(50);
  rightSensor.begin(0x29, &Wire);
  rightSensor.setAddress(ADDR_RIGHT);

  // down
  digitalWrite(XSHUT_DOWN, HIGH);
  delay(50);
  downSensor.begin(0x29, &Wire);
 
  //downSensor.setDistanceMode(VL53L1X_LONG); not for this lib 
  

  downSensor.startRanging();


  Serial.println("4 sensors Ready");
  

  // PWM Setup
 ledcAttach(leftmotor,PWM_FREQ,PWM_RES);
 ledcAttach(rightmotor,PWM_FREQ,PWM_RES);
 ledcWrite(leftmotor, 0);
 ledcWrite(rightmotor, 0);
}



